#include "sweep_qt_gui/mainwindow.h"
#include "sweep_qt_gui/ros2_manager.h"
#include "ui_mainwindow.h"

#include <QDateTime>
#include <QLabel>
#include <QListWidget>
#include <QPushButton>
#include <QVBoxLayout>
#include <QGridLayout>
#include <QFormLayout>
#include <QHBoxLayout>
#include <QGraphicsView>
#include <QGraphicsScene>
#include <QGraphicsTextItem>
#include <QPen>
#include <QBrush>
#include <QStringList>
#include <QPointF>
#include <QVector>
#include <QPainter>
#include <QTabWidget>

MainWindow::MainWindow(QWidget *parent)
    : QMainWindow(parent)
    , ui(new Ui::MainWindow)
    , ros2_manager_(new Ros2Manager(this))
    , monitor_x_label_(nullptr)
    , monitor_y_label_(nullptr)
    , monitor_yaw_label_(nullptr)
    , monitor_linear_label_(nullptr)
    , monitor_angular_label_(nullptr)
    , monitor_battery_label_(nullptr)
    , monitor_status_label_(nullptr)
    , map_view_(nullptr)
    , map_scene_(nullptr)
    , path_list_(nullptr)
    , info_log_list_(nullptr)
    , warn_log_list_(nullptr)
    , error_log_list_(nullptr)
    , low_battery_warned_(false)
{
    ui->setupUi(this);

    setWindowTitle("智能扫槽车上位机");

    ui->labelRosStatus->setText("未连接");
    ui->labelRobotStatus->setText("离线");
    ui->labelBattery->setText("-- %");
    ui->labelTask->setText("待机");

    ui->listMenu->clear();
    ui->listMenu->addItems({
        "首页总览",
        "参数设置",
        "地图与路径",
        "手动控制",
        "状态监控",
        "日志报警"
    });

    initPages();

    connect(ui->listMenu, &QListWidget::currentRowChanged,
            this, &MainWindow::onMenuChanged);

    connect(ui->btnConnectRos, &QPushButton::clicked,
            this, &MainWindow::onConnectRos);

    connect(ui->btnStartTask, &QPushButton::clicked,
            this, &MainWindow::onStartTask);

    connect(ui->btnPauseTask, &QPushButton::clicked,
            this, &MainWindow::onPauseTask);

    connect(ui->btnStopTask, &QPushButton::clicked,
            this, &MainWindow::onStopTask);

    connect(ui->btnBackCharge, &QPushButton::clicked,
            this, &MainWindow::onBackCharge);

    connect(ui->btnResetParams, &QPushButton::clicked,
            this, &MainWindow::onResetParams);

    connect(ui->btnSaveParams, &QPushButton::clicked,
            this, &MainWindow::onSaveParams);

    connect(ui->btnApplyParams, &QPushButton::clicked,
            this, &MainWindow::onApplyParams);

    connect(ros2_manager_, &Ros2Manager::rosConnected,
            this, &MainWindow::onRosConnected);

    connect(ros2_manager_, &Ros2Manager::statusReceived,
            this, &MainWindow::onStatusReceived);

    connect(ros2_manager_, &Ros2Manager::telemetryReceived,
            this, &MainWindow::onTelemetryReceived);

    ui->listMenu->setCurrentRow(0);

    appendInfoLog("界面初始化完成");
}

MainWindow::~MainWindow()
{
    delete ui;
}

void MainWindow::initPages()
{
    {
        QVBoxLayout *homeLayout = new QVBoxLayout(ui->pageHome);

        QLabel *label = new QLabel("首页总览页面");
        label->setAlignment(Qt::AlignCenter);
        label->setStyleSheet("font-size: 22px; font-weight: bold;");

        homeLayout->addStretch();
        homeLayout->addWidget(label);
        homeLayout->addStretch();
    }

    {
        QVBoxLayout *mapMainLayout = new QVBoxLayout(ui->pageMap);

        QLabel *mapTitle = new QLabel("地图与路径页面");
        mapTitle->setAlignment(Qt::AlignCenter);
        mapTitle->setStyleSheet("font-size: 22px; font-weight: bold;");

        QHBoxLayout *mapContentLayout = new QHBoxLayout();

        map_view_ = new QGraphicsView();
        map_scene_ = new QGraphicsScene(this);
        map_view_->setScene(map_scene_);
        map_view_->setRenderHint(QPainter::Antialiasing, true);
        map_view_->setMinimumSize(520, 360);

        QWidget *rightPanel = new QWidget();
        QVBoxLayout *rightLayout = new QVBoxLayout(rightPanel);

        QLabel *pathTitle = new QLabel("路径点列表");
        pathTitle->setStyleSheet("font-weight: bold;");

        path_list_ = new QListWidget();
        path_list_->setMinimumWidth(220);

        QPushButton *btnLoadMap = new QPushButton("加载示例地图");
        QPushButton *btnGeneratePath = new QPushButton("生成示例路径");
        QPushButton *btnClearMap = new QPushButton("清空地图/路径");

        connect(btnLoadMap, &QPushButton::clicked, this, &MainWindow::onLoadDemoMap);
        connect(btnGeneratePath, &QPushButton::clicked, this, &MainWindow::onGenerateDemoPath);
        connect(btnClearMap, &QPushButton::clicked, this, &MainWindow::onClearMapPath);

        rightLayout->addWidget(pathTitle);
        rightLayout->addWidget(path_list_);
        rightLayout->addWidget(btnLoadMap);
        rightLayout->addWidget(btnGeneratePath);
        rightLayout->addWidget(btnClearMap);
        rightLayout->addStretch();

        mapContentLayout->addWidget(map_view_, 3);
        mapContentLayout->addWidget(rightPanel, 1);

        mapMainLayout->addWidget(mapTitle);
        mapMainLayout->addLayout(mapContentLayout);
    }

    {
        QVBoxLayout *manualLayout = new QVBoxLayout(ui->pageManual);

        QLabel *manualTitle = new QLabel("手动控制页面");
        manualTitle->setAlignment(Qt::AlignCenter);
        manualTitle->setStyleSheet("font-size: 22px; font-weight: bold;");

        QGridLayout *grid = new QGridLayout();

        QPushButton *btnForward = new QPushButton("前进");
        QPushButton *btnBackward = new QPushButton("后退");
        QPushButton *btnLeft = new QPushButton("左转");
        QPushButton *btnRight = new QPushButton("右转");
        QPushButton *btnStop = new QPushButton("停止");

        btnForward->setMinimumSize(100, 50);
        btnBackward->setMinimumSize(100, 50);
        btnLeft->setMinimumSize(100, 50);
        btnRight->setMinimumSize(100, 50);
        btnStop->setMinimumSize(100, 50);

        grid->addWidget(btnForward, 0, 1);
        grid->addWidget(btnLeft, 1, 0);
        grid->addWidget(btnStop, 1, 1);
        grid->addWidget(btnRight, 1, 2);
        grid->addWidget(btnBackward, 2, 1);

        manualLayout->addStretch();
        manualLayout->addWidget(manualTitle);
        manualLayout->addLayout(grid);
        manualLayout->addStretch();

        connect(btnForward, &QPushButton::clicked, this, &MainWindow::onManualForward);
        connect(btnBackward, &QPushButton::clicked, this, &MainWindow::onManualBackward);
        connect(btnLeft, &QPushButton::clicked, this, &MainWindow::onManualLeft);
        connect(btnRight, &QPushButton::clicked, this, &MainWindow::onManualRight);
        connect(btnStop, &QPushButton::clicked, this, &MainWindow::onManualStop);
    }

    {
        QVBoxLayout *monitorMainLayout = new QVBoxLayout(ui->pageMonitor);

        QLabel *monitorTitle = new QLabel("状态监控页面");
        monitorTitle->setAlignment(Qt::AlignCenter);
        monitorTitle->setStyleSheet("font-size: 22px; font-weight: bold;");

        QFormLayout *monitorForm = new QFormLayout();

        monitor_x_label_ = new QLabel("0.00");
        monitor_y_label_ = new QLabel("0.00");
        monitor_yaw_label_ = new QLabel("0.00");
        monitor_linear_label_ = new QLabel("0.00");
        monitor_angular_label_ = new QLabel("0.00");
        monitor_battery_label_ = new QLabel("0");
        monitor_status_label_ = new QLabel("待机");

        monitorForm->addRow("X 坐标", monitor_x_label_);
        monitorForm->addRow("Y 坐标", monitor_y_label_);
        monitorForm->addRow("航向角 yaw", monitor_yaw_label_);
        monitorForm->addRow("线速度", monitor_linear_label_);
        monitorForm->addRow("角速度", monitor_angular_label_);
        monitorForm->addRow("电量", monitor_battery_label_);
        monitorForm->addRow("当前状态", monitor_status_label_);

        monitorMainLayout->addStretch();
        monitorMainLayout->addWidget(monitorTitle);
        monitorMainLayout->addSpacing(15);
        monitorMainLayout->addLayout(monitorForm);
        monitorMainLayout->addStretch();
    }

    {
        QVBoxLayout *logMainLayout = new QVBoxLayout(ui->pageLogs);

        QLabel *logTitle = new QLabel("日志报警页面");
        logTitle->setAlignment(Qt::AlignCenter);
        logTitle->setStyleSheet("font-size: 22px; font-weight: bold;");

        QTabWidget *logTabs = new QTabWidget();

        info_log_list_ = new QListWidget();
        warn_log_list_ = new QListWidget();
        error_log_list_ = new QListWidget();

        logTabs->addTab(info_log_list_, "普通日志");
        logTabs->addTab(warn_log_list_, "警告日志");
        logTabs->addTab(error_log_list_, "错误日志");

        QPushButton *btnClearLogs = new QPushButton("清空全部日志");
        connect(btnClearLogs, &QPushButton::clicked, this, &MainWindow::onClearLogs);

        logMainLayout->addWidget(logTitle);
        logMainLayout->addWidget(logTabs);
        logMainLayout->addWidget(btnClearLogs);
    }

    ui->speedSpin->setValue(1.0);
    ui->widthSpin->setValue(0.4);
    ui->intervalSpin->setValue(5);
    ui->lowBatterySpin->setValue(20);
    ui->modeCombo->setCurrentIndex(0);
}

void MainWindow::appendInfoLog(const QString &text)
{
    const QString time = QDateTime::currentDateTime().toString("yyyy-MM-dd hh:mm:ss");
    const QString line = "[" + time + "][INFO] " + text;

    ui->textLog->appendPlainText(line);
    if (info_log_list_) {
        info_log_list_->addItem(line);
        info_log_list_->scrollToBottom();
    }
}

void MainWindow::appendWarnLog(const QString &text)
{
    const QString time = QDateTime::currentDateTime().toString("yyyy-MM-dd hh:mm:ss");
    const QString line = "[" + time + "][WARN] " + text;

    ui->textLog->appendPlainText(line);
    if (warn_log_list_) {
        warn_log_list_->addItem(line);
        warn_log_list_->scrollToBottom();
    }
}

void MainWindow::appendErrorLog(const QString &text)
{
    const QString time = QDateTime::currentDateTime().toString("yyyy-MM-dd hh:mm:ss");
    const QString line = "[" + time + "][ERROR] " + text;

    ui->textLog->appendPlainText(line);
    if (error_log_list_) {
        error_log_list_->addItem(line);
        error_log_list_->scrollToBottom();
    }
}

QString MainWindow::buildParamsText() const
{
    return QString("speed=%1,width=%2,interval=%3,low_battery=%4,mode=%5")
        .arg(ui->speedSpin->value(), 0, 'f', 2)
        .arg(ui->widthSpin->value(), 0, 'f', 2)
        .arg(ui->intervalSpin->value())
        .arg(ui->lowBatterySpin->value())
        .arg(ui->modeCombo->currentText());
}

void MainWindow::drawDemoMapBase()
{
    map_scene_->clear();
    path_list_->clear();

    map_scene_->setSceneRect(0, 0, 600, 400);

    QPen gridPen(QColor(220, 220, 220));
    for (int x = 0; x <= 600; x += 50) {
        map_scene_->addLine(x, 0, x, 400, gridPen);
    }
    for (int y = 0; y <= 400; y += 50) {
        map_scene_->addLine(0, y, 600, y, gridPen);
    }

    QPen borderPen(Qt::black);
    borderPen.setWidth(2);
    map_scene_->addRect(0, 0, 600, 400, borderPen);

    QBrush obstacleBrush(QColor(180, 180, 180));
    map_scene_->addRect(120, 80, 80, 140, borderPen, obstacleBrush);
    map_scene_->addRect(300, 220, 120, 70, borderPen, obstacleBrush);
    map_scene_->addRect(470, 90, 60, 160, borderPen, obstacleBrush);

    map_scene_->addEllipse(40, 40, 20, 20, QPen(Qt::darkGreen), QBrush(Qt::green));
    map_scene_->addEllipse(540, 320, 20, 20, QPen(Qt::darkRed), QBrush(Qt::red));

    auto *startText = map_scene_->addText("Start");
    startText->setDefaultTextColor(Qt::darkGreen);
    startText->setPos(30, 15);

    auto *goalText = map_scene_->addText("Goal");
    goalText->setDefaultTextColor(Qt::darkRed);
    goalText->setPos(530, 345);
}

void MainWindow::onMenuChanged(int row)
{
    ui->stackedWidget->setCurrentIndex(row);
    appendInfoLog(QString("切换到页面索引：%1").arg(row));
}

void MainWindow::onConnectRos()
{
    appendInfoLog("开始连接 ROS2...");
    ros2_manager_->start();
}

void MainWindow::onStartTask()
{
    ui->labelTask->setText("作业中");
    ros2_manager_->sendTaskCommand("start");
    appendInfoLog("发送任务命令：start");
}

void MainWindow::onPauseTask()
{
    ui->labelTask->setText("已暂停");
    ros2_manager_->sendTaskCommand("pause");
    appendInfoLog("发送任务命令：pause");
}

void MainWindow::onStopTask()
{
    ui->labelTask->setText("已停止");
    ros2_manager_->sendTaskCommand("stop");
    appendInfoLog("发送任务命令：stop");
}

void MainWindow::onBackCharge()
{
    ui->labelTask->setText("回充中");
    ros2_manager_->sendTaskCommand("charge");
    appendInfoLog("发送任务命令：charge");
}

void MainWindow::onManualForward()
{
    ros2_manager_->sendCmdVel(0.5, 0.0);
    ui->labelTask->setText("手动控制");
    appendInfoLog("手动控制：前进");
}

void MainWindow::onManualBackward()
{
    ros2_manager_->sendCmdVel(-0.3, 0.0);
    ui->labelTask->setText("手动控制");
    appendInfoLog("手动控制：后退");
}

void MainWindow::onManualLeft()
{
    ros2_manager_->sendCmdVel(0.0, 0.8);
    ui->labelTask->setText("手动控制");
    appendInfoLog("手动控制：左转");
}

void MainWindow::onManualRight()
{
    ros2_manager_->sendCmdVel(0.0, -0.8);
    ui->labelTask->setText("手动控制");
    appendInfoLog("手动控制：右转");
}

void MainWindow::onManualStop()
{
    ros2_manager_->sendCmdVel(0.0, 0.0);
    ui->labelTask->setText("手动控制");
    appendInfoLog("手动控制：停止");
}

void MainWindow::onResetParams()
{
    ui->speedSpin->setValue(1.0);
    ui->widthSpin->setValue(0.4);
    ui->intervalSpin->setValue(5);
    ui->lowBatterySpin->setValue(20);
    ui->modeCombo->setCurrentIndex(0);

    appendInfoLog("参数已恢复默认");
}

void MainWindow::onSaveParams()
{
    appendInfoLog("参数已保存：" + buildParamsText());
}

void MainWindow::onApplyParams()
{
    const QString params = buildParamsText();
    ros2_manager_->sendProcessParams(params);
    appendInfoLog("参数已下发：" + params);
}

void MainWindow::onLoadDemoMap()
{
    drawDemoMapBase();
    ui->labelTask->setText("地图浏览");
    appendInfoLog("已加载示例地图");
}

void MainWindow::onGenerateDemoPath()
{
    drawDemoMapBase();

    QVector<QPointF> points = {
        QPointF(50, 50),
        QPointF(90, 50),
        QPointF(90, 260),
        QPointF(250, 260),
        QPointF(250, 330),
        QPointF(550, 330)
    };

    QPen pathPen(Qt::blue);
    pathPen.setWidth(3);

    for (int i = 0; i < points.size(); ++i) {
        map_scene_->addEllipse(points[i].x() - 4, points[i].y() - 4, 8, 8,
                               QPen(Qt::blue), QBrush(Qt::blue));

        path_list_->addItem(QString("P%1 : (%2, %3)")
                            .arg(i)
                            .arg(points[i].x(), 0, 'f', 0)
                            .arg(points[i].y(), 0, 'f', 0));

        if (i < points.size() - 1) {
            map_scene_->addLine(points[i].x(), points[i].y(),
                                points[i + 1].x(), points[i + 1].y(),
                                pathPen);
        }
    }

    ui->labelTask->setText("路径规划");
    appendInfoLog("已生成示例路径，共 6 个路径点");
}

void MainWindow::onClearMapPath()
{
    map_scene_->clear();
    path_list_->clear();
    ui->labelTask->setText("待机");
    appendInfoLog("已清空地图与路径显示");
}

void MainWindow::onClearLogs()
{
    ui->textLog->clear();

    if (info_log_list_) info_log_list_->clear();
    if (warn_log_list_) warn_log_list_->clear();
    if (error_log_list_) error_log_list_->clear();

    appendInfoLog("日志已清空");
}

void MainWindow::onRosConnected(bool ok)
{
    if (ok) {
        ui->labelRosStatus->setText("已连接");
        appendInfoLog("ROS2 连接成功");
    } else {
        ui->labelRosStatus->setText("连接失败");
        appendErrorLog("ROS2 未连接或命令发送失败");
    }
}

void MainWindow::onStatusReceived(const QString &status)
{
    ui->labelRobotStatus->setText(status);

    if (last_status_ != status) {
        appendInfoLog("收到机器人状态：" + status);
        last_status_ = status;
    }

    if (status == "作业中") {
        ui->labelTask->setText("作业中");
        ui->labelBattery->setText("85 %");
    } else if (status == "已暂停") {
        ui->labelTask->setText("已暂停");
    } else if (status == "已停止") {
        ui->labelTask->setText("已停止");
    } else if (status == "回充中") {
        ui->labelTask->setText("回充中");
        ui->labelBattery->setText("40 %");
    } else if (status == "参数已更新") {
        ui->labelTask->setText("参数设置");
    } else {
        ui->labelTask->setText(status);
    }
}

void MainWindow::onTelemetryReceived(const QString &telemetry)
{
    const QStringList parts = telemetry.split(',');

    QString x = "0.00";
    QString y = "0.00";
    QString yaw = "0.00";
    QString linear = "0.00";
    QString angular = "0.00";
    QString battery = "0";
    QString status = "待机";

    for (const QString &part : parts) {
        const QStringList kv = part.split('=');
        if (kv.size() != 2) {
            continue;
        }

        const QString key = kv[0].trimmed();
        const QString value = kv[1].trimmed();

        if (key == "x") x = value;
        else if (key == "y") y = value;
        else if (key == "yaw") yaw = value;
        else if (key == "linear") linear = value;
        else if (key == "angular") angular = value;
        else if (key == "battery") battery = value;
        else if (key == "status") status = value;
    }

    if (monitor_x_label_) monitor_x_label_->setText(x);
    if (monitor_y_label_) monitor_y_label_->setText(y);
    if (monitor_yaw_label_) monitor_yaw_label_->setText(yaw);
    if (monitor_linear_label_) monitor_linear_label_->setText(linear);
    if (monitor_angular_label_) monitor_angular_label_->setText(angular);
    if (monitor_battery_label_) monitor_battery_label_->setText(battery + " %");
    if (monitor_status_label_) monitor_status_label_->setText(status);

    ui->labelBattery->setText(battery + " %");

    bool ok = false;
    int battery_value = battery.toInt(&ok);
    if (ok) {
        if (battery_value <= 20 && !low_battery_warned_) {
            appendWarnLog("电量低于 20%，建议尽快回充");
            low_battery_warned_ = true;
        } else if (battery_value > 20) {
            low_battery_warned_ = false;
        }
    }
}
